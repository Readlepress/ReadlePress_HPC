# ReadlePress Development Environment
# NEVER use these values in production — all production secrets live in AWS Secrets Manager

DATABASE_URL=postgresql://app_rw:app_rw_dev_password@localhost:5432/readlepress
DATABASE_ADMIN_URL=postgresql://readlepress_admin:dev_password_only@localhost:5432/readlepress
REDIS_URL=redis://:dev_redis_password@localhost:6379

JWT_SECRET=dev_jwt_secret_256bit_minimum_key_for_development_only
JWT_EXPIRY=3600

PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# SMS Provider (MSG91)
MSG91_API_KEY=dev_placeholder
MSG91_SENDER_ID=RDLPRS

# eMudhra (PDF signing)
EMUDHRA_SIGNING_CERT_PATH=./certs/dev.pem
EMUDHRA_TSA_URL=https://tsa.emudhra.com/dev

# AI Provider
AI_PROVIDER_KEY=dev_placeholder
