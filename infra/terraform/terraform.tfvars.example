# =============================================================================
# ReadlePress Terraform Variables Example
# Copy to terraform.tfvars and fill in values
# =============================================================================

aws_region   = "ap-south-1"
environment  = "dev"  # dev | staging | prod

# -----------------------------------------------------------------------------
# VPC
# -----------------------------------------------------------------------------
vpc_cidr = "10.0.0.0/16"
availability_zones = ["ap-south-1a", "ap-south-1b"]

# -----------------------------------------------------------------------------
# RDS (sensitive - use TF_VAR_ or -var for production)
# -----------------------------------------------------------------------------
db_name           = "readlepress"
db_master_username = "readlepress_admin"
# db_master_password = "CHANGE_ME"  # Set via TF_VAR_db_master_password

# -----------------------------------------------------------------------------
# ElastiCache
# -----------------------------------------------------------------------------
redis_num_cache_clusters = 1

# -----------------------------------------------------------------------------
# CloudFront
# -----------------------------------------------------------------------------
cloudfront_price_class = "PriceClass_200"

# -----------------------------------------------------------------------------
# WAF
# -----------------------------------------------------------------------------
waf_rate_limit = 2000

# -----------------------------------------------------------------------------
# Tags
# -----------------------------------------------------------------------------
tags = {
  Team = "Platform"
}
